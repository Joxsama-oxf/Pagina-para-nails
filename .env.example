# ============================================================
#  Laura Nails - Plantilla de variables de entorno
# ============================================================
# Copia este archivo como ".env" y rellena los valores reales.
# El archivo .env NUNCA se sube a Git (esta en .gitignore).

# Clave secreta de Flask. Genera una con:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Token para re-ejecutar /configurar-sistema cuando ya hay usuarios. Genera con:
#   python -c "import secrets; print(secrets.token_urlsafe(24))"
SETUP_TOKEN=

# Modo debug: 1 = desarrollo, 0 = produccion.
FLASK_DEBUG=0

# Token de la Graph API de Facebook/Instagram (seccion Redes). Opcional.
IG_TOKEN=

# Contrasenas de los usuarios demo que crea /configurar-sistema.
SEED_PASS_ADMIN=
SEED_PASS_MANI1=
SEED_PASS_MANI2=
SEED_PASS_MANI3=
